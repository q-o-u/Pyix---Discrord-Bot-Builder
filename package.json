{
  "name": "pyix-bot-builder",
  "version": "1.0.0",
  "description": "No-code Discord Bot Builder with glassmorphic UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.pyix.botbuilder",
    "productName": "Pyix",
    "win": {
      "target": "portable",
      "icon": "renderer/icon.ico"
    },
    "portable": {
      "artifactName": "Pyix.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "discord.js": "^14.14.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1"
  },
  "author": "Pyix",
  "license": "AGPL-3.0"
}
